# Copy to .env and fill in your API keys
# .env is gitignored — never commit real keys

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Amadeus (free sandbox at https://developers.amadeus.com)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# OpenWeatherMap (free tier at https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# Google Maps Platform (https://console.cloud.google.com — enable Maps, Places APIs)
GOOGLE_MAPS_API_KEY=

# Ticketmaster Discovery (https://developer.ticketmaster.com)
TICKETMASTER_API_KEY=

# Trip.com (partner API — contact Trip.com for access)
TRIPDOTCOM_API_KEY=

# Google Calendar (service account JSON, base64-encoded or raw JSON string)
GOOGLE_CALENDAR_CREDENTIALS_JSON=

# Sherpa visa API (https://developer.sherpa.to)
SHERPA_API_KEY=

# OpenTable (partner API)
OPENTABLE_API_KEY=
